# ============================================================
# VisioBin Environment Variables Example
# Salin file ini ke .env dan isi nilai yang sesuai.
# Jangan commit file .env yang berisi rahasia asli.
# ============================================================

# Database
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=visiobin
DB_HOST=postgres
DB_PORT=5432
DB_HOST_PORT=5433
DB_SSLMODE=disable

# Backend auth
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRY_HOURS=72
API_KEY=your_iot_api_key_change_me

# Firebase
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-service-account.json

# Backend / Web
BACKEND_PORT=8082
DASHBOARD_PORT=3000
ADMINER_PORT=8081
ADMINER_CONTAINER_PORT=8080
NEXT_PUBLIC_API_URL=http://localhost:8082/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Mobile
API_BASE_URL=http://192.168.1.3:8082/api/v1
WS_BASE_URL=ws://192.168.1.3:8082/ws

# Camera / AI
CAMERA_STREAM_URL=http://192.168.1.10:8000/stream
CAMERA_STREAM_HOST=0.0.0.0
CAMERA_STREAM_PORT=8000
CAMERA_CAPTURE_WIDTH=1640
CAMERA_CAPTURE_HEIGHT=1232
VISIOBIN_BACKEND=http://localhost:8082/api/v1/classifications
VISIOBIN_BACKEND_API_BASE=http://localhost:8082/api/v1
VISIOBIN_ONNX=best.onnx
VISIOBIN_WEIGHTS=best.pt
VISIOBIN_BIN_ID=VBIN-01
VISIOBIN_CAMERA=0
VISIOBIN_THRESHOLD=0.75
VISIOBIN_COOLDOWN=3.0
VISIOBIN_UART_PORT=/dev/ttyUSB0
VISIOBIN_UART_BAUD=115200
VISIOBIN_INTERVAL=5.0

# Simulator
SIMULATOR_API_URL=http://backend:8082/api/v1
SIMULATOR_INTERVAL=5
SIMULATOR_USER=your_simulator_user
SIMULATOR_PASSWORD=your_simulator_password
SIMULATOR_SCENARIO=default
