# ============================================================
# VisioBin Environment Variables Example
# Salin file ini ke .env dan isi nilai yang sesuai.
# JANGAN perna men-commit file .env yang berisi rahasia asli!
# ============================================================

# ── Database (PostgreSQL) ───────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=visiobin
DB_HOST=postgres
DB_PORT=5432

# ── JWT ─────────────────────────────────────────────────────
# Gunakan string panjang dan acak untuk produksi
JWT_SECRET=your_super_secret_key_change_me

# ── Firebase Cloud Messaging (FCM) ──────────────────────────
# Path ke file service account JSON di dalam container
GOOGLE_APPLICATION_CREDENTIALS=/app/firebase-service-account.json

# ── Frontend / Dashboard ────────────────────────────────────
# URL API untuk diakses oleh browser klien
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
