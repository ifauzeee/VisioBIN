# ============================================================
# VisioBin Backend — Environment Configuration
# Salin file ini ke .env dan isi nilainya sebelum menjalankan server
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=8080
ENV=development    # development | production

# ── Database (PostgreSQL) ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=visiobin
DB_SSLMODE=disable

# URL lengkap (opsional, override individu di atas jika di-set)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/visiobin?sslmode=disable

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=ganti-ini-dengan-secret-yang-panjang-dan-aman
JWT_EXPIRY_HOURS=72

# ── Firebase Cloud Messaging (FCM) ──────────────────────────
# Untuk mengaktifkan push notification ke Flutter mobile app.
# Pilih SALAH SATU metode di bawah:

# Metode 1 (RECOMMENDED): Path ke file service account JSON dari Firebase Console
# Download dari: Firebase Console → Project Settings → Service Accounts → Generate new private key
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json

# Metode 2: JSON inline (cocok untuk Docker/Kubernetes secrets)
# FCM_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── Rate Limiting ────────────────────────────────────────────
# Maksimum request per menit per IP address
RATE_LIMIT_RPM=120

# ── AI Bridge / IoT Device ──────────────────────────────────
# Konfigurasi untuk script di Raspberry Pi (ai_bridge.py, uart_bridge.py)
VISIOBIN_BIN_ID=VBIN-01
VISIOBIN_BACKEND=http://localhost:8080/api/v1/classifications
VISIOBIN_THRESHOLD=0.85
VISIOBIN_COOLDOWN=3.0
VISIOBIN_UART_PORT=/dev/ttyUSB0
VISIOBIN_UART_BAUD=115200
