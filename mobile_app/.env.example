# VisioBin Mobile Environment Variables Template
# Copy this file to .env and adjust the values

# Base URL for Backend API
# Use http://10.0.2.2:8080/api/v1 for Android Emulator
# Use http://localhost:8080/api/v1 for iOS Simulator
# Use your local IP (e.g., http://192.168.1.3:8080/api/v1) for physical devices
API_BASE_URL=http://192.168.1.3:8080/api/v1

# Base URL for WebSocket (Chat System)
# Replace http with ws in your API URL
WS_BASE_URL=ws://192.168.1.3:8080/ws
