                    </div>
                  </div>
                ) : (
                  <EmptyState
                    title="Prediksi Tidak Tersedia"
                    description="Diperlukan data sensor minimal 2 titik untuk menghitung prediksi."
                  />
                )}
              </motion.div>
            </div>
          </motion.div>
        ) : null}
      </AnimatePresence>
    </>
  );
}
