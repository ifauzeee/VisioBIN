                        size: 14,
                        color: const Color(0xFF10b981).withValues(alpha: 0.7),
                      ),
                      const SizedBox(width: 6),
                      Text(
                        'Diamankan oleh Protokol VisioBin',
                        style: TextStyle(
                          fontSize: 12,
                          color: isDark ? Colors.white38 : Colors.black38,
                        ),
                      ),
                    ],
                  ),
                ],
              ),
            ),
          ),
        ),
      ),
    );
  }
}
